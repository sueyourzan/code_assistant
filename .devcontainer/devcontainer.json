{
  "name": "DeepSeek Code Assistant",
  // 1. 移除 image，改用 build 指定 Dockerfile
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--memory=4g",
    "--cpus=4"
  ],
  "mounts": [    
    "source=pip-cache,target=/home/vscode/.cache/pip,type=volume"
  ],
  // 2. 移除 Python 和 Git 的 Features，因为 Dockerfile 已经处理了
  // Git 通常在基础镜像中已包含，无需重复安装
  "features": {},
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "streamlit.streamlit"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.analysis.autoSearchPaths": false,
        "terminal.integrated.defaultProfile.linux": "bash",
        "python.terminal.executeInFileDir": true
      }
    }
  },
  // 3. 环境变量保留在这里或 Dockerfile 的 ENV 中均可
  "containerEnv": {
    "PYTHONNOUSERSITE": "1",
    "PIP_INDEX_URL": "https://pipy.tuna.tsinghua.edu.cn/simple",
    "PIP_TRUSTED_HOST": "pipy.tuna.tsinghua.edu.cn"
  },
  // 4. 移除 postCreateCommand，因为 Dockerfile 的 RUN 已经安装了依赖
  // "postCreateCommand": "..." // 删除此行
  "remoteUser": "vscode"
  // 5. 移除 postAttachCommand，避免用户组冲突
  // "postAttachCommand": "..." // 删除此行
}